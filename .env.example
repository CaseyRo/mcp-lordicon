# Lordicon REST API (outbound auth)
# Get a Bearer token from https://lordicon.com/account/api
LORDICON_TOKEN=

# Optional — override if self-hosting or testing against a mock.
LORDICON_URL=https://api.lordicon.com

# Inbound bearer auth (REQUIRED when TRANSPORT=http)
# 32-byte random; must match the bearer the Cloudflare tunnel / MCP client sends.
MCP_API_KEY=

# Transport: stdio (local dev) or http (Docker / production)
TRANSPORT=stdio

# HTTP mode binding
HOST=127.0.0.1
PORT=8000
